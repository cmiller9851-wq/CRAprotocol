# Function: Core cryptographic smoke test to verify block sequencing

import os
import json
import hashlib
from datetime import datetime

def compute_block_hash(block_data: dict) -> str:
    """Serializes a dictionary deterministically and returns its SHA-256 hash."""
    # sort_keys ensures identical data structures always output the exact same hash
    serialized = json.dumps(block_data, sort_keys=True).encode('utf-8')
    return hashlib.sha256(serialized).hexdigest()

