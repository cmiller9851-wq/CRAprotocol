name: "Stripe Payout Hold Release & Stack Verification"

on:
  schedule:
    - cron: '0 */6 * * *'
  workflow_dispatch:

jobs:
  verify-and-release:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Repository Code
        uses: actions/checkout@v4

      - name: Set Up Python Environment
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'

      - name: Install System Dependencies
        run: |
          python -m pip install --upgrade pip
          pip install stripe requests

      - name: Execute Verification Stack
        env:
          STRIPE_API_KEY: ${{ secrets.STRIPE_API_KEY }}
          STRIPE_ACCOUNT_ID: ${{ secrets.STRIPE_ACCOUNT_ID }}
        run: |
          if [ -f "stripe_payout_hold_release.py" ]; then
            python stripe_payout_hold_release.py
          else
            echo "::error::Core script stripe_payout_hold_release.py not found in root directory."
            exit 1
          fi

      - name: Archive Compliance Report Artifact
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: stripe-compliance-report
          path: stripe_compliance_report.json
          retention-days: 90
